---
import Layout from '../layouts/Layout.astro';
---

<Layout title="百变街舞 - 少儿街舞培训专家">
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">百变<span>街舞</span></a>
      <ul class="nav-links">
        <li><a href="/">首页</a></li>
        <li><a href="/courses">课程体系</a></li>
        <li><a href="/teachers">师资团队</a></li>
        <li><a href="/honors">荣誉资质</a></li>
        <li><a href="/news">街舞资讯</a></li>
        <li><a href="/reviews">学员评价</a></li>
        <li><a href="/blog">博客</a></li>
        <li><a href="/faq">常见问题</a></li>
        <li><a href="/contact">联系我们</a></li>
      </ul>
      <a href="/contact" class="cta-btn">立即咨询</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="container">
        <h1 class="hero-title">
          <span class="line">在这里</span>
          <span class="line">拥有自己的舞台</span>
        </h1>
        <p class="hero-subtitle">百变潮童学院 - 少儿街舞培训专家</p>
        <div class="hero-tags">
          <span class="tag">Hip-hop</span>
          <span class="tag">Jazz</span>
          <span class="tag">Urban</span>
          <span class="tag">Locking</span>
        </div>
        <div class="hero-btns">
          <a href="/courses" class="btn btn-primary">查看课程</a>
          <a href="/contact" class="btn btn-outline">预约试课</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section about">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2>关于<span style="color:var(--primary)">百变</span></h2>
          <p>专注于少儿街舞教育</p>
          <h3>让中国青少年儿童变得更快乐、更有活力、更自信、更闪耀</h3>
          <p class="desc">百变街舞创办于2017年，是中国舞蹈家协会街舞委员会会员单位，专注4-18岁青少年儿童街舞培训。</p>
          <div class="about-stats">
            <div class="stat">
              <span class="stat-num">8+</span>
              <span class="stat-label">年教学经验</span>
            </div>
            <div class="stat">
              <span class="stat-num">1000+</span>
              <span class="stat-label">学员总数</span>
            </div>
            <div class="stat">
              <span class="stat-num">50+</span>
              <span class="stat-label">获奖荣誉</span>
            </div>
          </div>
        </div>
        <div class="about-visual">
          <img src="/img/image9.jpeg" alt="课堂" class="about-img" />
          <img src="/img/image10.jpeg" alt="表演" class="about-img about-img-2" />
          <img src="/img/image32.jpeg" alt="活动" class="about-img about-img-3" />
        </div>
      </div>
    </div>
  </section>

  <section class="section courses" id="courses">
    <div class="container">
      <div class="section-title">
        <h2>课程<span style="color:var(--primary)">体系</span></h2>
        <p>科学阶梯式成长方案</p>
      </div>
      <div class="courses-grid">
        <div class="course-card">
          <img src="/img/image8.jpeg" alt="幼儿街舞" class="course-img" />
          <div class="course-icon">🧒</div>
          <h3>幼儿街舞启蒙</h3>
          <p class="course-age">4-6岁</p>
          <p class="course-desc">Hip-hop舞种，1-2级内容</p>
          <div class="course-tag">零基础入门</div>
        </div>
        <div class="course-card">
          <img src="/img/image9.jpeg" alt="少儿街舞" class="course-img" />
          <div class="course-icon">👦</div>
          <h3>少儿街舞进阶</h3>
          <p class="course-age">7-12岁</p>
          <p class="course-desc">Hip-hop/Jazz/Urban，3-6级内容</p>
          <div class="course-tag">技能提升</div>
        </div>
        <div class="course-card">
          <img src="/img/image10.jpeg" alt="中高级街舞" class="course-img" />
          <div class="course-icon">👱</div>
          <h3>中高级进阶</h3>
          <p class="course-age">12-16岁</p>
          <p class="course-desc">Hip-hop/Jazz/Urban，6-10级内容</p>
          <div class="course-tag">专业突破</div>
        </div>
        <div class="course-card featured">
          <img src="/img/image11.jpeg" alt="明星特训营" class="course-img" />
          <div class="course-icon">⭐</div>
          <h3>明星特训营</h3>
          <p class="course-age">4-18岁</p>
          <p class="course-desc">VIP课程，导师精排成品舞</p>
          <div class="course-tag">VIP课程</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section teachers">
    <div class="container">
      <div class="section-title">
        <h2>师资<span style="color:var(--primary)">团队</span></h2>
        <p>专业导师团队</p>
      </div>
      <div class="teachers-grid">
        <div class="teacher-card">
          <img src="/img/dongxiangjun.jpg" alt="董香君" class="teacher-avatar" />
          <h3>董香君</h3>
          <p class="teacher-title">创始人</p>
          <div class="teacher-info">
            <span>舞龄 10 年</span>
            <span>教龄 8 年</span>
          </div>
          <p class="teacher-cert">中国舞蹈家协会舞蹈教师</p>
        </div>
        <div class="teacher-card">
          <img src="/img/yangtan.png" alt="杨檀" class="teacher-avatar" />
          <h3>杨檀</h3>
          <p class="teacher-title">高级导师</p>
          <div class="teacher-info">
            <span>舞龄 10 年</span>
            <span>教学 6 年</span>
          </div>
          <p class="teacher-cert">青少年街舞培训师</p>
        </div>
        <div class="teacher-card">
          <img src="/img/bingbing.jpg" alt="冰冰" class="teacher-avatar" />
          <h3>冰冰</h3>
          <p class="teacher-title">全能导师</p>
          <div class="teacher-info">
            <span>舞龄 7 年</span>
            <span>教龄 5 年</span>
          </div>
          <p class="teacher-cert">CHUC爵士舞师资考官</p>
        </div>
        <div class="teacher-card">
          <img src="/img/tingting.jpeg" alt="婷婷" class="teacher-avatar" />
          <h3>婷婷</h3>
          <p class="teacher-title">全能导师</p>
          <div class="teacher-info">
            <span>舞龄 7 年</span>
            <span>教龄 5 年</span>
          </div>
          <p class="teacher-cert">JAZZ进修教师</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section honors">
    <div class="container">
      <div class="section-title">
        <h2>荣誉<span style="color:var(--primary)">资质</span></h2>
        <p>权威认证 品质保证</p>
      </div>
      <div class="honors-grid">
        <div class="honor-item">
          <img src="/img/image28.jpeg" alt="考级单位" class="honor-img" />
          <h3>中国舞蹈家协会</h3>
          <p>指定考级单位</p>
        </div>
        <div class="honor-item">
          <img src="/img/image29.jpg" alt="理事单位" class="honor-img" />
          <h3>临汾市舞蹈家协会</h3>
          <p>常务理事单位</p>
        </div>
        <div class="honor-item">
          <img src="/img/image30.jpeg" alt="优秀单位" class="honor-img" />
          <h3>山西省优秀培训单位</h3>
          <p>权威认证</p>
        </div>
        <div class="honor-item">
          <img src="/img/image31.jpeg" alt="电视台" class="honor-img" />
          <h3>山西广播电视台</h3>
          <p>合作单位</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <div class="cta-box">
        <h2>开启你的街舞之旅</h2>
        <p>立即预约免费试课，让孩子爱上舞蹈</p>
        <a href="/contact" class="btn btn-primary">立即预约</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>百变街舞</h3>
          <p>百变潮童学院 - 专注少儿街舞培训<br/>让每个孩子都能在舞台上发光</p>
        </div>
        <div class="footer-col">
          <h4>课程</h4>
          <ul>
            <li><a href="/courses">幼儿街舞启蒙</a></li>
            <li><a href="/courses">少儿街舞进阶</a></li>
            <li><a href="/courses">中高级进阶</a></li>
            <li><a href="/courses">明星特训营</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>关于</h4>
          <ul>
            <li><a href="/teachers">师资团队</a></li>
            <li><a href="/honors">荣誉资质</a></li>
            <li><a href="/news">街舞资讯</a></li>
            <li><a href="/reviews">学员评价</a></li>
            <li><a href="/blog">博客文章</a></li>
            <li><a href="/faq">常见问题</a></li>
            <li><a href="/contact">联系我们</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>联系</h4>
          <ul>
            <li>山西省临汾市尧都区</li>
            <li>河汾四路58号伍磅健身一层</li>
            <li>国王餐厅北150米</li>
            <li>📞 19035772680</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 百变街舞 版权所有 | 地址：山西省临汾市尧都区河汾四路58号伍磅健身一层（国王餐厅北150米）</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--dark);
    position: relative;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(255,220,0,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(255,51,102,0.1) 0%, transparent 50%);
  }
  .hero-content {
    text-align: center;
    z-index: 1;
  }
  .hero-title {
    font-size: 72px;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .hero-title .line {
    display: block;
  }
  .hero-title .line:first-child { color: var(--light); }
  .hero-title .line:last-child { color: var(--primary); }
  .hero-subtitle {
    font-size: 20px;
    color: var(--gray);
    margin-bottom: 30px;
  }
  .hero-tags {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-bottom: 40px;
  }
  .tag {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 14px;
    color: var(--gray);
  }
  .hero-btns {
    display: flex;
    justify-content: center;
    gap: 20px;
  }
  .btn {
    display: inline-block;
    padding: 16px 40px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    transition: all 0.3s;
  }
  .btn-primary { background: var(--primary); color: var(--dark); }
  .btn-primary:hover { background: var(--secondary); transform: translateY(-3px); }
  .btn-outline { border: 2px solid var(--light); color: var(--light); }
  .btn-outline:hover { background: var(--light); color: var(--dark); }

  .section { padding: 100px 0; }
  .section-title { text-align: center; margin-bottom: 60px; }
  .section-title h2 { font-size: 42px; font-weight: 900; text-transform: uppercase; margin-bottom: 15px; }
  .section-title p { color: var(--gray); font-size: 16px; }

  .about { background: linear-gradient(180deg, var(--dark), var(--dark-2)); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .about-content h2 { text-align: left; font-size: 42px; margin-bottom: 10px; }
  .about-content > p { color: var(--gray); margin-bottom: 20px; }
  .about-content h3 { font-size: 24px; margin-bottom: 20px; line-height: 1.5; }
  .about-desc { color: var(--gray); line-height: 1.8; margin-bottom: 20px; }
  .about-stats { display: flex; gap: 40px; margin-top: 40px; }
  .stat { text-align: center; }
  .stat-num { display: block; font-size: 42px; font-weight: 900; color: var(--primary); }
  .stat-label { font-size: 14px; color: var(--gray); text-transform: uppercase; }

  .about-visual { display: flex; gap: 15px; flex-wrap: wrap; justify-content: center; }
  .about-img { width: 180px; height: 240px; object-fit: cover; border-radius: 15px; border: 3px solid var(--primary); }
  .about-img-2 { margin-top: 40px; }
  .about-img-3 { margin-top: 20px; }

  .courses { background: var(--dark-2); }
  .courses-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 25px; }
  .course-card {
    background: var(--dark);
    border-radius: 20px;
    padding: 0 20px 25px;
    text-align: center;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }
  .course-card:hover { border-color: var(--primary); transform: translateY(-8px); }
  .course-img { width: 100%; height: 150px; object-fit: cover; border-radius: 12px; margin-bottom: 15px; margin-top: 20px; }
  .course-icon { font-size: 48px; margin-bottom: 15px; }
  .course-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
  .course-age { color: var(--primary); font-weight: 700; margin-bottom: 10px; }
  .course-desc { color: var(--gray); font-size: 14px; margin-bottom: 15px; }
  .course-tag { display: inline-block; background: var(--dark-2); padding: 6px 15px; border-radius: 15px; font-size: 12px; color: var(--secondary); }
  .course-card.featured { border-color: var(--secondary); background: linear-gradient(180deg, rgba(0,212,255,0.1), var(--dark)); }

  .teachers { background: var(--dark); }
  .teachers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .teacher-card { background: var(--dark-2); border-radius: 20px; padding: 30px 20px; text-align: center; border: 1px solid var(--dark-3); transition: all 0.3s; }
  .teacher-card:hover { border-color: var(--primary); transform: translateY(-5px); }
  .teacher-avatar { width: 120px; height: 150px; object-fit: cover; border-radius: 10px; margin-bottom: 20px; border: 3px solid var(--primary); }
  .teacher-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 5px; }
  .teacher-title { color: var(--primary); font-size: 14px; text-transform: uppercase; margin-bottom: 15px; }
  .teacher-info { display: flex; justify-content: center; gap: 15px; margin-bottom: 15px; font-size: 13px; color: var(--gray); }
  .teacher-cert { font-size: 13px; color: var(--gray); }

  .honors { background: var(--dark-2); }
  .honors-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .honor-item { background: var(--dark); border-radius: 20px; padding: 20px; text-align: center; border: 1px solid var(--dark-3); transition: all 0.3s; }
  .honor-item:hover { border-color: var(--primary); }
  .honor-img { width: 100%; height: 180px; object-fit: contain; margin-bottom: 15px; border-radius: 8px; background: #fff; padding: 10px; }
  .honor-item h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .honor-item p { color: var(--gray); font-size: 14px; }

  .cta { background: linear-gradient(135deg, var(--dark), var(--dark-2)); }
  .cta-box { background: linear-gradient(135deg, rgba(255,220,0,0.15), rgba(255,51,102,0.15)); border-radius: 30px; padding: 80px 40px; text-align: center; border: 1px solid rgba(255,220,0,0.2); }
  .cta-box h2 { font-size: 42px; font-weight: 900; text-transform: uppercase; margin-bottom: 15px; }
  .cta-box p { color: var(--gray); font-size: 18px; margin-bottom: 35px; }

  .footer { background: var(--dark-2); padding: 60px 0 30px; border-top: 1px solid var(--dark-3); }
  .footer-content { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
  .footer-brand h3 { font-size: 28px; font-weight: 900; color: var(--primary); margin-bottom: 10px; }
  .footer-brand p { color: var(--gray); font-size: 14px; line-height: 1.7; }
  .footer h4 { font-size: 16px; font-weight: 700; margin-bottom: 20px; text-transform: uppercase; }
  .footer ul { list-style: none; }
  .footer ul li { margin-bottom: 10px; color: var(--gray); font-size: 14px; }
  .footer a { color: var(--gray); }
  .footer a:hover { color: var(--primary); }
  .footer-bottom { text-align: center; padding-top: 30px; border-top: 1px solid var(--dark-3); color: var(--gray); font-size: 14px; }

  @media (max-width: 1024px) {
    .courses-grid, .teachers-grid, .honors-grid { grid-template-columns: repeat(2, 1fr); }
    .about-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hero-title { font-size: 42px; }
    .nav-links { display: none; }
    .about-grid { grid-template-columns: 1fr; }
    .about-visual { display: none; }
    .courses-grid, .teachers-grid, .honors-grid { grid-template-columns: 1fr; }
    .footer-content { grid-template-columns: 1fr; text-align: center; }
  }
</style>
