---
import Layout from '../layouts/Layout.astro';
---

<Layout title="师资团队 - 百变街舞">
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">百变<span>街舞</span></a>
      <ul class="nav-links">
        <li><a href="/">首页</a></li>
        <li><a href="/courses">课程体系</a></li>
        <li><a href="/teachers">师资团队</a></li>
        <li><a href="/honors">荣誉资质</a></li>
        <li><a href="/about">关于我们</a></li>
        <li><a href="/contact">联系我们</a></li>
      </ul>
      <a href="/contact" class="cta-btn">立即咨询</a>
    </div>
  </nav>

  <header class="page-header">
    <div class="container">
      <h1>师资<span>团队</span></h1>
      <p>专业导师团队</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <!-- 创始人 -->
      <div class="founder-section">
        <div class="founder-card">
          <img src="/img/dongxiangjun.jpg" alt="创始人" class="founder-img" />
          <div class="founder-info">
            <span class="founder-tag">创始人</span>
            <h2>董香君</h2>
            <div class="founder-stats">
              <div class="stat">
                <span class="stat-num">10</span>
                <span class="stat-label">年舞龄</span>
              </div>
              <div class="stat">
                <span class="stat-num">8</span>
                <span class="stat-label">年教龄</span>
              </div>
            </div>
            <div class="founder-certs">
              <div class="cert">中国舞蹈家协会舞蹈教师</div>
              <div class="cert">国际舞者协会培训师</div>
              <div class="cert">四级编导职称</div>
              <div class="cert">中国东方街舞团高级教师</div>
              <div class="cert">WDC世界舞蹈总会街舞国际评审</div>
              <div class="cert">中国高等院校教师资格证</div>
            </div>
            <div class="founder-timeline">
              <div class="timeline-item">
                <span class="year">2017</span>
                <span class="desc">荣获中国舞蹈家协会舞蹈教师、国际舞者协会培训师证书</span>
              </div>
              <div class="timeline-item">
                <span class="year">2019</span>
                <span class="desc">荣获乐舞潮童进修宝宝、入门、初级、中高级教师资格证书</span>
              </div>
              <div class="timeline-item">
                <span class="year">2025</span>
                <span class="desc">王牌师训高阶师训王牌学员</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 核心导师 -->
      <div class="section-title">
        <h2>核心<span style="color: var(--primary);">导师</span></h2>
        <p>资深教学团队</p>
      </div>

      <div class="teachers-grid">
        <div class="teacher-card">
          <img src="/img/yangtan.png" alt="杨檀" class="teacher-avatar" />
          <div class="teacher-content">
            <span class="teacher-badge">高级导师</span>
            <h3>杨檀</h3>
            <div class="teacher-stats">
              <span>舞龄 10 年</span>
              <span>教学 6 年</span>
            </div>
            <div class="teacher-certs">
              <span>青少年街舞培训师</span>
              <span>NSEC街舞师资认证高级导师</span>
              <span>非丹教学法幼少儿街舞系统课编创人</span>
              <span>著名编舞师</span>
              <span>非丹大师课导师</span>
            </div>
            <p class="teacher-intro">深耕街舞教育十五年，擅长HIP-HOP编舞，舞领潮15年，教学6年，拥有北京流行舞研修基地的教师资格证，擅长多风格编舞</p>
          </div>
        </div>

        <div class="teacher-card">
          <img src="/img/bingbing.jpg" alt="冰冰" class="teacher-avatar" />
          <div class="teacher-content">
            <span class="teacher-badge">全能导师</span>
            <h3>冰冰</h3>
            <div class="teacher-stats">
              <span>舞龄 7 年</span>
              <span>教龄 5 年</span>
            </div>
            <div class="teacher-certs">
              <span>CHUC爵士舞全国师资考官</span>
              <span>CHUC爵士舞全国考级考官</span>
              <span>CHUC综合街舞全国师资考官</span>
              <span>CHUC综合街舞全国考级考官</span>
              <span>CHUC爵士舞教师资格证</span>
              <span>CHUC街舞教师资格证</span>
            </div>
            <p class="teacher-intro">四级编导职称，中国东方街舞团高级教师，JAZZ进修，非丹教师特训，进修于乐舞潮童少儿教学学习</p>
          </div>
        </div>

        <div class="teacher-card">
          <img src="/img/tingting.jpeg" alt="婷婷" class="teacher-avatar" />
          <div class="teacher-content">
            <span class="teacher-badge">全能导师</span>
            <h3>婷婷</h3>
            <div class="teacher-stats">
              <span>舞龄 7 年</span>
              <span>教龄 5 年</span>
            </div>
            <div class="teacher-certs">
              <span>教师资格证</span>
              <span>JAZZ进修</span>
              <span>非丹教师特训</span>
              <span>非丹门徒班特训进阶</span>
            </div>
            <p class="teacher-intro">专注Jazz教学，多次参加各类街舞大赛，持有教师资格证，专业能力强，教学经验丰富</p>
          </div>
        </div>

        <div class="teacher-card">
          <img src="/img/zhuzhulaoshi.png" alt="朱朱老师" class="teacher-avatar" />
          <div class="teacher-content">
            <span class="teacher-badge">流行舞艺考专业导师</span>
            <h3>朱朱老师</h3>
            <div class="teacher-stats">
              <span>舞龄 8 年</span>
              <span>教学 4 年</span>
            </div>
            <div class="teacher-certs">
              <span>毕业于山东体育学院舞蹈专业</span>
              <span>CSDA全国街舞委员会裁判</span>
              <span>持有教师资格证</span>
            </div>
            <p class="teacher-intro">专业舞蹈功底扎实，擅长Hip-hop教学，多次参加各类街舞比赛并获得优异成绩</p>
          </div>
        </div>
      </div>

      <!-- 教学理念 -->
      <div class="philosophy-section">
        <div class="philosophy-content">
          <h2>教学理念</h2>
          <p>百变街舞汲取国际前沿少儿街舞教育理念，融合乐舞潮童、非丹等权威教学体系的精髓，经由百变资深教师团队历时七年的本土化研发、系统化实践、数据化反馈与迭代化升级，最终锻造而成的一套科学化、阶梯式、全方位的少儿街舞成长方案。</p>
          <p>该体系以循序渐进、因材施教为核心，构建了从启蒙开发到高阶掌握的完整进阶路径，涵盖<strong>兴趣激发→基础奠基→技能强化→风格塑造→专业突破</strong>五大成长阶段，确保每一位学员在科学引导下，逐步实现从街舞爱好者到未来舞者的华丽蜕变。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container">
      <div class="cta-box">
        <h2>跟随名师学街舞</h2>
        <p>立即预约，免费试课</p>
        <a href="/contact" class="btn btn-primary">立即预约</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>百变街舞</h3>
          <p>百变潮童学院 - 专注少儿街舞培训</p>
        </div>
        <div class="footer-col">
          <h4>联系</h4>
          <ul>
            <li>山西省临汾市尧都区</li>
            <li>河汾四路58号</li>
            <li>国王餐厅北150米</li>
            <li>📞 19035772680</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 百变街舞 版权所有</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .page-header {
    padding: 160px 0 60px;
    text-align: center;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .page-header h1 {
    font-size: 48px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
  }

  .page-header h1 span {
    color: var(--primary);
  }

  .page-header p {
    color: var(--gray);
    margin-top: 15px;
    font-size: 18px;
  }

  .founder-section {
    margin-bottom: 80px;
  }

  .founder-card {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 60px;
    background: var(--dark-2);
    border-radius: 30px;
    padding: 50px;
    border: 2px solid var(--primary);
  }

  .founder-img {
    height: 450px;
    border-radius: 20px;
    object-fit: cover;
    width: 100%;
    background: linear-gradient(135deg, rgba(255,220,0,0.2) 0%, rgba(255,220,0,0.05) 100%);
    border: 1px solid rgba(255,220,0,0.3);
  }

  .founder-tag {
    display: inline-block;
    background: var(--primary);
    color: var(--dark);
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 15px;
  }

  .founder-info h2 {
    font-size: 36px;
    font-weight: 900;
    margin-bottom: 20px;
  }

  .founder-stats {
    display: flex;
    gap: 40px;
    margin-bottom: 25px;
  }

  .stat {
    text-align: center;
  }

  .stat-num {
    display: block;
    font-size: 36px;
    font-weight: 900;
    color: var(--primary);
  }

  .stat-label {
    font-size: 14px;
    color: var(--gray);
  }

  .founder-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 30px;
  }

  .cert {
    background: var(--dark);
    padding: 8px 15px;
    border-radius: 15px;
    font-size: 13px;
    color: var(--gray);
    border: 1px solid var(--dark-3);
  }

  .founder-timeline {
    border-top: 1px solid var(--dark-3);
    padding-top: 20px;
  }

  .timeline-item {
    display: flex;
    gap: 20px;
    margin-bottom: 12px;
  }

  .timeline-item .year {
    color: var(--primary);
    font-weight: 700;
    min-width: 50px;
  }

  .timeline-item .desc {
    color: var(--gray);
    font-size: 14px;
  }

  .teachers-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin-bottom: 80px;
  }

  .teacher-card {
    background: var(--dark-2);
    border-radius: 25px;
    overflow: hidden;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }

  .teacher-card:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
  }

  .teacher-avatar {
    width: 100%;
    height: 250px;
    object-fit: contain;
    object-position: center center;
    background: linear-gradient(135deg, var(--dark-3) 0%, var(--dark) 100%);
    border-bottom: 1px solid var(--dark-3);
  }

  .teacher-content {
    padding: 30px;
  }

  .teacher-badge {
    display: inline-block;
    background: var(--secondary);
    color: var(--dark);
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .teacher-card h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .teacher-stats {
    display: flex;
    gap: 20px;
    color: var(--primary);
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 15px;
  }

  .teacher-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 15px;
  }

  .teacher-certs span {
    background: var(--dark);
    padding: 5px 10px;
    border-radius: 10px;
    font-size: 11px;
    color: var(--gray);
  }

  .teacher-intro {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.7;
  }

  .philosophy-section {
    background: var(--dark-2);
    border-radius: 30px;
    padding: 60px;
    text-align: center;
  }

  .philosophy-content h2 {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 25px;
  }

  .philosophy-content p {
    color: var(--gray);
    font-size: 16px;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto 20px;
  }

  .philosophy-content strong {
    color: var(--primary);
  }

  .cta {
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .cta-box {
    background: linear-gradient(135deg, rgba(255,220,0,0.15) 0%, rgba(255,51,102,0.15) 100%);
    border-radius: 30px;
    padding: 80px 40px;
    text-align: center;
    border: 1px solid rgba(255,220,0,0.2);
  }

  .cta-box h2 {
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 15px;
  }

  .cta-box p {
    color: var(--gray);
    font-size: 16px;
    margin-bottom: 35px;
  }

  .btn {
    display: inline-block;
    padding: 16px 40px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--dark);
  }

  .btn-primary:hover {
    background: var(--secondary);
    transform: translateY(-3px);
  }

  .footer {
    background: var(--dark-2);
    padding: 60px 0 30px;
    border-top: 1px solid var(--dark-3);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-brand h3 {
    font-size: 28px;
    font-weight: 900;
    color: var(--primary);
    margin-bottom: 10px;
  }

  .footer-brand p {
    color: var(--gray);
    font-size: 14px;
  }

  .footer h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .footer ul {
    list-style: none;
  }

  .footer ul li {
    color: var(--gray);
    font-size: 14px;
    margin-bottom: 10px;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 30px;
    border-top: 1px solid var(--dark-3);
    color: var(--gray);
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .founder-card {
      grid-template-columns: 1fr;
    }

    .teachers-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .founder-card {
      padding: 30px;
    }
  }
</style>
