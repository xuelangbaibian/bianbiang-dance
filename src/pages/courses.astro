---
import Layout from '../layouts/Layout.astro';
---

<Layout title="课程体系 - 百变街舞">
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">百变<span>街舞</span></a>
      <ul class="nav-links">
        <li><a href="/">首页</a></li>
        <li><a href="/courses">课程体系</a></li>
        <li><a href="/teachers">师资团队</a></li>
        <li><a href="/honors">荣誉资质</a></li>
        <li><a href="/about">关于我们</a></li>
        <li><a href="/contact">联系我们</a></li>
      </ul>
      <a href="/contact" class="cta-btn">立即咨询</a>
    </div>
  </nav>

  <header class="page-header">
    <div class="container">
      <h1>课程<span>体系</span></h1>
      <p>科学阶梯式成长方案</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <!-- 课程特色 -->
      <div class="course-feature">
        <div class="feature-icon">📚</div>
        <h2>课程特色</h2>
        <div class="feature-grid">
          <div class="feature-item">
            <h3>多元化课程</h3>
            <p>专业教学课程系统 + 研发团队打造幼少儿街舞10级课程体系，以趣味授课方式加深孩子兴趣度，以因材施教定制班级学习计划</p>
          </div>
          <div class="feature-item">
            <h3>舞台表演</h3>
            <p>多元化舞台表演课程的学习，以在我们提供的平台展示、活动机会和表演实战来提升孩子舞台表现力</p>
          </div>
          <div class="feature-item">
            <h3>多种班型</h3>
            <p>同时推出集训、提升动作质感的打铁班、街舞少年团以及流行舞艺考预备班等多种课程班型和学习阶段</p>
          </div>
        </div>
      </div>

      <!-- 课程体系 -->
      <div class="section-title">
        <h2>四大<span style="color: var(--primary);">课程</span></h2>
        <p>适合不同年龄段</p>
      </div>

      <div class="courses-list">
        <div class="course-row">
          <img src="/img/image8.jpeg" alt="幼儿街舞启蒙" class="course-img" />
          <div class="course-info">
            <span class="course-tag">启蒙</span>
            <h3>幼儿街舞启蒙</h3>
            <p class="course-age">适龄4-6岁</p>
            <ul class="course-list">
              <li>Hip-hop 舞种</li>
              <li>1-2级内容</li>
              <li>导师精排成品舞</li>
              <li>基础素质培养</li>
            </ul>
          </div>
        </div>

        <div class="course-row reverse">
          <img src="/img/image9.jpeg" alt="少儿街舞进阶" class="course-img" />
          <div class="course-info">
            <span class="course-tag">进阶</span>
            <h3>少儿街舞进阶</h3>
            <p class="course-age">适龄7-12岁</p>
            <ul class="course-list">
              <li>Hip-hop / Jazz / Urban</li>
              <li>3-6级内容</li>
              <li>导师精排成品舞</li>
              <li>专业技能提升</li>
            </ul>
          </div>
        </div>

        <div class="course-row">
          <img src="/img/image10.jpeg" alt="中高级进阶" class="course-img" />
          <div class="course-info">
            <span class="course-tag">提升</span>
            <h3>中高级进阶</h3>
            <p class="course-age">适龄12-16岁</p>
            <ul class="course-list">
              <li>Hip-hop / Jazz / Urban</li>
              <li>6-10级内容</li>
              <li>导师精排成品舞</li>
              <li>进阶元素技巧</li>
            </ul>
          </div>
        </div>

        <div class="course-row reverse">
          <img src="/img/image11.jpeg" alt="明星特训营" class="course-img" />
          <div class="course-info">
            <span class="course-tag featured">VIP</span>
            <h3>明星特训营</h3>
            <p class="course-age">适龄4-18岁</p>
            <ul class="course-list">
              <li>Hip-hop / Jazz / Urban</li>
              <li>导师精排成品舞</li>
              <li>形象表情管理</li>
              <li>专业技能提升</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- 舞种介绍 -->
      <div class="section-title" style="margin-top: 80px;">
        <h2>舞种<span style="color: var(--primary);">介绍</span></h2>
      </div>

      <div class="dance-styles">
        <div class="style-card">
          <div class="style-icon">🎤</div>
          <h3>Hip-hop</h3>
          <p>最经典的街舞舞种，节奏感强，风格自由，源自美国街头文化</p>
        </div>
        <div class="style-card">
          <div class="style-icon">💃</div>
          <h3>Jazz</h3>
          <p>爵士舞，节奏鲜明，动作优雅，兼具力量与柔美</p>
        </div>
        <div class="style-card">
          <div class="style-icon">🔥</div>
          <h3>Urban</h3>
          <p>编舞风格，融合多种元素，强调创意和舞台表现力</p>
        </div>
        <div class="style-card">
          <div class="style-icon">🔒</div>
          <h3>Locking</h3>
          <p>锁舞，节奏欢快，动作精准，表演张力十足</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container">
      <div class="cta-box">
        <h2>开启孩子的街舞之旅</h2>
        <p>立即预约免费试课，感受街舞魅力</p>
        <a href="/contact" class="btn btn-primary">立即预约</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>百变街舞</h3>
          <p>百变潮童学院 - 专注少儿街舞培训</p>
        </div>
        <div class="footer-col">
          <h4>联系</h4>
          <ul>
            <li>山西省临汾市尧都区</li>
            <li>河汾四路58号</li>
            <li>国王餐厅北150米</li>
            <li>📞 19035772680</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 百变街舞 版权所有</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .page-header {
    padding: 160px 0 60px;
    text-align: center;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .page-header h1 {
    font-size: 48px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
  }

  .page-header h1 span {
    color: var(--primary);
  }

  .page-header p {
    color: var(--gray);
    margin-top: 15px;
    font-size: 18px;
  }

  /* 课程特色 */
  .course-feature {
    background: var(--dark-2);
    border-radius: 30px;
    padding: 60px;
    margin-bottom: 80px;
    text-align: center;
  }

  .feature-icon {
    font-size: 60px;
    margin-bottom: 20px;
  }

  .course-feature h2 {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 40px;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .feature-item {
    text-align: left;
  }

  .feature-item h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--primary);
  }

  .feature-item p {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.7;
  }

  /* 课程列表 */
  .courses-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .course-row {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 50px;
    align-items: center;
    background: var(--dark-2);
    border-radius: 30px;
    padding: 40px;
    border: 1px solid var(--dark-3);
  }

  .course-row.reverse {
    direction: rtl;
  }

  .course-row.reverse .course-info {
    direction: ltr;
  }

  .course-img {
    height: 280px;
    border-radius: 20px;
    object-fit: cover;
    width: 100%;
  }

  .course-info {
    padding: 20px 0;
  }

  .course-tag {
    display: inline-block;
    background: var(--primary);
    color: var(--dark);
    padding: 5px 15px;
    border-radius: 15px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 15px;
  }

  .course-tag.featured {
    background: var(--secondary);
  }

  .course-info h3 {
    font-size: 28px;
    font-weight: 900;
    margin-bottom: 8px;
  }

  .course-age {
    color: var(--primary);
    font-weight: 700;
    font-size: 16px;
    margin-bottom: 20px;
  }

  .course-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .course-list li {
    color: var(--gray);
    font-size: 14px;
    padding-left: 20px;
    position: relative;
  }

  .course-list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--primary);
  }

  /* 舞种 */
  .dance-styles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }

  .style-card {
    background: var(--dark-2);
    border-radius: 20px;
    padding: 40px 25px;
    text-align: center;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }

  .style-card:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
  }

  .style-icon {
    font-size: 48px;
    margin-bottom: 20px;
  }

  .style-card h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .style-card p {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.6;
  }

  /* CTA */
  .cta {
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .cta-box {
    background: linear-gradient(135deg, rgba(255,220,0,0.15) 0%, rgba(255,51,102,0.15) 100%);
    border-radius: 30px;
    padding: 80px 40px;
    text-align: center;
    border: 1px solid rgba(255,220,0,0.2);
  }

  .cta-box h2 {
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 15px;
  }

  .cta-box p {
    color: var(--gray);
    font-size: 16px;
    margin-bottom: 35px;
  }

  .btn {
    display: inline-block;
    padding: 16px 40px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--dark);
  }

  .btn-primary:hover {
    background: var(--secondary);
    transform: translateY(-3px);
  }

  /* Footer */
  .footer {
    background: var(--dark-2);
    padding: 60px 0 30px;
    border-top: 1px solid var(--dark-3);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-brand h3 {
    font-size: 28px;
    font-weight: 900;
    color: var(--primary);
    margin-bottom: 10px;
  }

  .footer-brand p {
    color: var(--gray);
    font-size: 14px;
  }

  .footer h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .footer ul {
    list-style: none;
  }

  .footer ul li {
    color: var(--gray);
    font-size: 14px;
    margin-bottom: 10px;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 30px;
    border-top: 1px solid var(--dark-3);
    color: var(--gray);
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .dance-styles {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .course-row {
      grid-template-columns: 1fr;
    }

    .course-row.reverse {
      direction: ltr;
    }

    .dance-styles {
      grid-template-columns: 1fr;
    }
  }
</style>
