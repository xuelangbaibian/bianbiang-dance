---
import Layout from '../layouts/Layout.astro';
---

<Layout title="荣誉资质 - 百变街舞">
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">百变<span>街舞</span></a>
      <ul class="nav-links">
        <li><a href="/">首页</a></li>
        <li><a href="/courses">课程体系</a></li>
        <li><a href="/teachers">师资团队</a></li>
        <li><a href="/honors">荣誉资质</a></li>
        <li><a href="/about">关于我们</a></li>
        <li><a href="/contact">联系我们</a></li>
      </ul>
      <a href="/contact" class="cta-btn">立即咨询</a>
    </div>
  </nav>

  <header class="page-header">
    <div class="container">
      <h1>荣誉<span>资质</span></h1>
      <p>权威认证 · 荣誉认证</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <!-- 机构资质 -->
      <div class="section-title">
        <h2>机构<span style="color: var(--primary);">资质</span></h2>
        <p>官方认证 · 权威资质</p>
      </div>

      <div class="cert-grid">
        <div class="cert-card">
          <div class="cert-icon">🏆</div>
          <h3>中国舞蹈家协会</h3>
          <h4>街舞委员会会员单位</h4>
          <p>中国舞蹈家协会是由中国文化部主管的全国性舞蹈艺术组织，是中国舞蹈界的最高权威机构</p>
        </div>

        <div class="cert-card">
          <div class="cert-icon">📜</div>
          <h3>指定考级中心</h3>
          <h4>中国舞蹈家协会街舞考级</h4>
          <p>作为指定考级单位，学员可在本机构完成1-10级街舞考级，获得权威认证</p>
        </div>

        <div class="cert-card">
          <div class="cert-icon">⭐</div>
          <h3>山西省优秀</h3>
          <h4>少儿艺术培训单位</h4>
          <p>荣获山西省权威部门认可的专业少儿艺术培训机构</p>
        </div>

        <div class="cert-card">
          <div class="cert-icon">🎯</div>
          <h3>8年教学经验</h3>
          <h4>专注少儿街舞培训</h4>
          <p>自2017年创办以来，累计服务学员1000+，教学经验丰富</p>
        </div>
      </div>

      <!-- 教师资质 -->
      <div class="section-title" style="margin-top: 80px;">
        <h2>教师<span style="color: var(--primary);">资质</span></h2>
        <p>专业认证 · 权威师资</p>
      </div>

      <div class="teacher-certs">
        <div class="teacher-cert-item">
          <img src="/img/cert1.png" alt="中国舞蹈家协会教师资格证" class="cert-img" />
          <div class="cert-info">
            <h3>中国舞蹈家协会教师资格证</h3>
            <p>创始人董香君荣获中国舞蹈家协会颁发的舞蹈教师资格证书，具备教授中国街舞艺术教育考级课程的资质</p>
          </div>
        </div>

        <div class="teacher-cert-item">
          <img src="/img/cert2.png" alt="国际舞者协会培训师" class="cert-img" />
          <div class="cert-info">
            <h3>国际舞者协会培训师</h3>
            <p>国际认证的舞蹈培训师资质，具备国际视野的舞蹈教学能力</p>
          </div>
        </div>

        <div class="teacher-cert-item">
          <img src="/img/cert3.png" alt="CHUC街舞考级考官" class="cert-img" />
          <div class="cert-info">
            <h3>CHUC全国街舞考级考官</h3>
            <p>多位导师具备CHUC中国街舞委员会颁发的师资考官和考级考官资质</p>
          </div>
        </div>

        <div class="teacher-cert-item">
          <img src="/img/cert4.png" alt="WDC国际评审" class="cert-img" />
          <div class="cert-info">
            <h3>WDC世界舞蹈总会街舞国际评审</h3>
            <p>具备国际认可的街舞比赛评审资质</p>
          </div>
        </div>

        <div class="teacher-cert-item">
          <img src="/img/cert5.png" alt="四级编导职称" class="cert-img" />
          <div class="cert-info">
            <h3>四级编导职称</h3>
            <p>专业舞蹈编导职称，具备舞蹈创作和编排能力</p>
          </div>
        </div>
      </div>

      <!-- 荣誉奖项 -->
      <div class="section-title" style="margin-top: 80px;">
        <h2>荣誉<span style="color: var(--primary);">奖项</span></h2>
        <p>50+荣誉奖项 · 实力见证</p>
      </div>

      <div class="honors-grid">
        <div class="honor-card">
          <img src="/img/honor1.png" alt="荣誉证书" class="honor-img" />
          <div class="honor-info">
            <h3>各类大赛奖项</h3>
            <p>学员在各类街舞大赛中荣获50+奖项</p>
          </div>
        </div>

        <div class="honor-card">
          <img src="/img/honor2.png" alt="荣誉证书" class="honor-img" />
          <div class="honor-info">
            <h3>优秀组织单位</h3>
            <p>多次获得各类街舞大赛优秀组织单位称号</p>
          </div>
        </div>

        <div class="honor-card">
          <img src="/img/honor3.png" alt="荣誉证书" class="honor-img" />
          <div class="honor-info">
            <h3>教学成果显著</h3>
            <p>专业教学成果受到家长和业界广泛认可</p>
          </div>
        </div>
      </div>

      <!-- 品牌优势 -->
      <div class="section-title" style="margin-top: 80px;">
        <h2>品牌<span style="color: var(--primary);">优势</span></h2>
      </div>

      <div class="advantages">
        <div class="advantage-item">
          <span class="advantage-num">01</span>
          <h3>权威认证</h3>
          <p>中国舞蹈家协会街舞委员会会员单位，官方认证更放心</p>
        </div>

        <div class="advantage-item">
          <span class="advantage-num">02</span>
          <h3>专业师资</h3>
          <p>所有导师均持有教师资格证，专业教学有保障</p>
        </div>

        <div class="advantage-item">
          <span class="advantage-num">03</span>
          <h3>考级中心</h3>
          <p>官方指定考级中心，在家门口就能完成街舞考级</p>
        </div>

        <div class="advantage-item">
          <span class="advantage-num">04</span>
          <h3>8年经验</h3>
          <p>8年教学经验，累计服务1000+学员</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container">
      <div class="cta-box">
        <h2>选择百变街舞</h2>
        <p>让孩子在权威专业的环境中学习街舞</p>
        <a href="/contact" class="btn btn-primary">立即咨询</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>百变街舞</h3>
          <p>百变潮童学院 - 专注少儿街舞培训</p>
        </div>
        <div class="footer-col">
          <h4>联系</h4>
          <ul>
            <li>山西省临汾市尧都区</li>
            <li>河汾四路58号</li>
            <li>国王餐厅北150米</li>
            <li>📞 19035772680</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 百变街舞 版权所有</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .page-header {
    padding: 160px 0 60px;
    text-align: center;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .page-header h1 {
    font-size: 48px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
  }

  .page-header h1 span {
    color: var(--primary);
  }

  .page-header p {
    color: var(--gray);
    margin-top: 15px;
    font-size: 18px;
  }

  .section-title {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-title h2 {
    font-size: 42px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 15px;
  }

  .section-title p {
    color: var(--gray);
    font-size: 16px;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    margin-bottom: 40px;
  }

  .cert-card {
    background: var(--dark-2);
    border-radius: 20px;
    padding: 40px 25px;
    text-align: center;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }

  .cert-card:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
  }

  .cert-icon {
    font-size: 48px;
    margin-bottom: 20px;
  }

  .cert-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--primary);
  }

  .cert-card h4 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .cert-card p {
    color: var(--gray);
    font-size: 13px;
    line-height: 1.6;
  }

  .teacher-certs {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .teacher-cert-item {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 40px;
    background: var(--dark-2);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid var(--dark-3);
    align-items: center;
  }

  .cert-img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    background: var(--dark);
  }

  .cert-info h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--primary);
  }

  .cert-info p {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.7;
  }

  .honors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .honor-card {
    background: var(--dark-2);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }

  .honor-card:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
  }

  .honor-img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    background: var(--dark);
  }

  .honor-info {
    padding: 25px;
  }

  .honor-info h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .honor-info p {
    color: var(--gray);
    font-size: 14px;
  }

  .advantages {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  .advantage-item {
    text-align: center;
    padding: 30px 20px;
    background: var(--dark-2);
    border-radius: 20px;
    border: 1px solid var(--dark-3);
  }

  .advantage-num {
    display: block;
    font-size: 36px;
    font-weight: 900;
    color: var(--primary);
    margin-bottom: 15px;
  }

  .advantage-item h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .advantage-item p {
    color: var(--gray);
    font-size: 13px;
    line-height: 1.6;
  }

  .cta {
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
    margin-top: 60px;
  }

  .cta-box {
    background: linear-gradient(135deg, rgba(255,220,0,0.15) 0%, rgba(255,51,102,0.15) 100%);
    border-radius: 30px;
    padding: 80px 40px;
    text-align: center;
    border: 1px solid rgba(255,220,0,0.2);
  }

  .cta-box h2 {
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 15px;
  }

  .cta-box p {
    color: var(--gray);
    font-size: 16px;
    margin-bottom: 35px;
  }

  .btn {
    display: inline-block;
    padding: 16px 40px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--dark);
  }

  .btn-primary:hover {
    background: var(--secondary);
    transform: translateY(-3px);
  }

  .footer {
    background: var(--dark-2);
    padding: 60px 0 30px;
    border-top: 1px solid var(--dark-3);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-brand h3 {
    font-size: 28px;
    font-weight: 900;
    color: var(--primary);
    margin-bottom: 10px;
  }

  .footer-brand p {
    color: var(--gray);
    font-size: 14px;
  }

  .footer h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .footer ul {
    list-style: none;
  }

  .footer ul li {
    color: var(--gray);
    font-size: 14px;
    margin-bottom: 10px;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 30px;
    border-top: 1px solid var(--dark-3);
    color: var(--gray);
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .cert-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .advantages {
      grid-template-columns: repeat(2, 1fr);
    }

    .teacher-cert-item {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .cert-grid {
      grid-template-columns: 1fr;
    }

    .honors-grid {
      grid-template-columns: 1fr;
    }

    .advantages {
      grid-template-columns: 1fr;
    }
  }
</style>
