---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('news');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
};

const categoryColors: Record<string, string> = {
  '艺考政策': '#FFDC00',
  '舞蹈知识': '#00D4FF',
  '赛事资讯': '#FF3366',
  '艺考指南': '#9B59B6',
  '家长指南': '#2ECC71'
};
---

<Layout title="街舞资讯 - 百变街舞" description="最新街舞资讯、艺考政策、舞蹈知识、赛事报道">
  <div class="page-header">
    <div class="container">
      <h1>街舞<span style="color:var(--primary)">资讯</span></h1>
      <p>权威街舞新闻、艺考政策、舞蹈知识</p>
    </div>
  </div>

  <section class="section news-section">
    <div class="container">
      <div class="news-grid">
        {sortedPosts.map((post) => (
          <article class="news-card">
            <a href={`/news/${post.slug}`} class="news-link">
              <div class="news-image">
                <img src={post.data.image || '/img/image9.jpeg'} alt={post.data.title} />
                <span class="news-category" style={`background: ${categoryColors[post.data.category] || '#FFDC00'}`}>
                  {post.data.category}
                </span>
              </div>
              <div class="news-content">
                <div class="news-meta">
                  <span class="news-date">{formatDate(post.data.pubDate)}</span>
                  <span class="news-author">{post.data.author}</span>
                </div>
                <h2 class="news-title">{post.data.title}</h2>
                <p class="news-desc">{post.data.description}</p>
                <div class="news-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="news-cta">
        <h2>想了解更多街舞资讯？</h2>
        <p>关注百变街舞，每周更新街舞新闻、艺考政策、舞蹈知识</p>
        <a href="/contact" class="btn btn-primary">联系我们</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 160px 0 80px;
    text-align: center;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .page-header h1 {
    font-size: 56px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 4px;
    margin-bottom: 15px;
  }

  .page-header p {
    color: var(--gray);
    font-size: 18px;
  }

  .news-section {
    background: var(--dark-2);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin-bottom: 60px;
  }

  .news-card {
    background: var(--dark);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }

  .news-card:hover {
    border-color: var(--primary);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(255, 220, 0, 0.1);
  }

  .news-link {
    display: block;
  }

  .news-image {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .news-card:hover .news-image img {
    transform: scale(1.1);
  }

  .news-category {
    position: absolute;
    top: 15px;
    left: 15px;
    padding: 5px 12px;
    border-radius: 15px;
    font-size: 12px;
    font-weight: 700;
    color: var(--dark);
  }

  .news-content {
    padding: 25px;
  }

  .news-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 13px;
    color: var(--gray);
  }

  .news-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-desc {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 12px;
    color: var(--secondary);
  }

  .news-cta {
    text-align: center;
    background: linear-gradient(135deg, rgba(255,220,0,0.1), rgba(255,51,102,0.1));
    border-radius: 30px;
    padding: 60px 40px;
    border: 1px solid rgba(255,220,0,0.2);
  }

  .news-cta h2 {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .news-cta p {
    color: var(--gray);
    margin-bottom: 30px;
  }

  .btn {
    display: inline-block;
    padding: 14px 35px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--dark);
  }

  .btn-primary:hover {
    background: var(--secondary);
    transform: translateY(-3px);
  }

  @media (max-width: 1024px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 36px;
    }
  }
</style>
