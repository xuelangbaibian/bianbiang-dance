---
import Layout from '../layouts/Layout.astro';
---

<Layout title="联系我们 - 百变街舞">
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">百变<span>街舞</span></a>
      <ul class="nav-links">
        <li><a href="/">首页</a></li>
        <li><a href="/courses">课程体系</a></li>
        <li><a href="/teachers">师资团队</a></li>
        <li><a href="/honors">荣誉资质</a></li>
        <li><a href="/about">关于我们</a></li>
        <li><a href="/contact">联系我们</a></li>
      </ul>
      <a href="/contact" class="cta-btn">立即咨询</a>
    </div>
  </nav>

  <header class="page-header">
    <div class="container">
      <h1>联系我们</h1>
      <p>欢迎来到百变街舞</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>联系我们</h2>
          <p class="info-desc">百变街舞专注少儿街舞培训，欢迎预约试课或咨询课程详情。</p>
          
          <div class="info-item">
            <div class="info-icon">📍</div>
            <div class="info-content">
              <h3>校区地址</h3>
              <p>山西省临汾市尧都区河汾四路58号伍磅健身一层</p>
              <span class="info-tag">国王餐厅北150米</span>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📱</div>
            <div class="info-content">
              <h3>联系电话</h3>
              <p class="phone">19035772680</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">🕐</div>
            <div class="info-content">
              <h3>营业时间</h3>
              <p>周一至周五：14:00 - 21:00</p>
              <p>周六至周日：09:00 - 21:00</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">🎯</div>
            <div class="info-content">
              <h3>服务范围</h3>
              <p>少儿街舞培训 | 成人街舞 | 流行舞 | 艺考</p>
            </div>
          </div>
        </div>

        <div class="contact-map">
          <div class="map-container">
            <a href="https://uri.amap.com/marker?position=111.5189,36.0877&name=伍磅健身&callnative=1" target="_blank" class="map-link">
              <span class="map-icon">📍</span>
              <span class="map-title">百变街舞</span>
              <span class="map-address">山西省临汾市尧都区河汾四路58号伍磅健身一层</span>
              <span class="map-action">点击查看地图 ></span>
            </a>
          </div>
        </div>
      </div>

      <div class="consult-section">
        <div class="consult-card">
          <h2>立即预约试课</h2>
          <p>填写以下信息，我们会在24小时内与您联系</p>
          <form class="consult-form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">孩子姓名</label>
                <input type="text" id="name" name="name" placeholder="请输入孩子姓名" />
              </div>
              <div class="form-group">
                <label for="age">孩子年龄</label>
                <select id="age" name="age">
                  <option value="">请选择年龄</option>
                  <option value="4-6">4-6岁</option>
                  <option value="7-12">7-12岁</option>
                  <option value="13-16">13-16岁</option>
                  <option value="17+">17岁以上</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="phone">联系电话</label>
                <input type="tel" id="phone" name="phone" placeholder="请输入联系电话" />
              </div>
              <div class="form-group">
                <label for="course">意向课程</label>
                <select id="course" name="course">
                  <option value="">请选择课程</option>
                  <option value="hiphop">Hip-hop</option>
                  <option value="jazz">Jazz</option>
                  <option value="urban">Urban</option>
                  <option value="locking">Locking</option>
                  <option value="star">明星特训营</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="message">留言</label>
              <textarea id="message" name="message" rows="4" placeholder="请输入留言内容（可选）"></textarea>
            </div>
            <button type="submit" class="submit-btn">提交预约</button>
          </form>
        </div>
      </div>

      <div class="guide-section">
        <div class="section-title">
          <h2>交通<span style="color: var(--primary);">指南</span></h2>
        </div>
        <div class="guide-grid">
          <div class="guide-card">
            <div class="guide-icon">🚗</div>
            <h3>自驾</h3>
            <p>导航至"国王餐厅"，学校位于餐厅北150米处，有停车位</p>
          </div>
          <div class="guide-card">
            <div class="guide-icon">🚌</div>
            <h3>公交</h3>
            <p>乘坐市区公交至河汾四路站，下车后步行约200米</p>
          </div>
          <div class="guide-card">
            <div class="guide-icon">🚕</div>
            <h3>打车</h3>
            <p>告诉司机目的地为"国王餐厅"即可</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>百变街舞</h3>
          <p>百变潮童学院 - 专注少儿街舞培训<br/>让每个孩子都能在舞台上发光</p>
        </div>
        <div class="footer-col">
          <h4>课程</h4>
          <ul>
            <li><a href="/courses">幼儿街舞启蒙</a></li>
            <li><a href="/courses">少儿街舞进阶</a></li>
            <li><a href="/courses">中高级进阶</a></li>
            <li><a href="/courses">明星特训营</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>关于</h4>
          <ul>
            <li><a href="/teachers">师资团队</a></li>
            <li><a href="/honors">荣誉资质</a></li>
            <li><a href="/contact">联系我们</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>联系</h4>
          <ul>
            <li>山西省临汾市尧都区</li>
            <li>河汾四路58号伍磅健身一层</li>
            <li>国王餐厅北150米</li>
            <li>📞 19035772680</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 百变街舞 版权所有 | 地址：山西省临汾市尧都区河汾四路58号伍磅健身一层（国王餐厅北150米）</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .page-header {
    padding: 160px 0 60px;
    text-align: center;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
  }

  .page-header h1 {
    font-size: 48px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
  }

  .page-header p {
    color: var(--gray);
    margin-top: 15px;
    font-size: 18px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    margin-bottom: 80px;
  }

  .contact-info h2 {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .info-desc {
    color: var(--gray);
    font-size: 16px;
    margin-bottom: 35px;
    line-height: 1.7;
  }

  .info-item {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
  }

  .info-icon {
    font-size: 36px;
    min-width: 50px;
  }

  .info-content h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .info-content p {
    color: var(--gray);
    font-size: 15px;
    margin-bottom: 5px;
  }

  .info-tag {
    display: inline-block;
    background: rgba(255,220,0,0.1);
    color: var(--primary);
    padding: 4px 12px;
    border-radius: 10px;
    font-size: 12px;
  }

  .phone {
    font-size: 20px !important;
    font-weight: 700;
    color: var(--primary) !important;
  }

  .map-container {
    width: 100%;
    height: 400px;
    border-radius: 15px;
    overflow: hidden;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
  }

  .map-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: var(--gray);
    transition: all 0.3s;
  }

  .map-link:hover {
    background: var(--dark-3);
  }

  .map-icon {
    font-size: 48px;
    margin-bottom: 15px;
  }

  .map-title {
    font-size: 20px;
    color: var(--primary);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .map-address {
    font-size: 14px;
    margin-bottom: 15px;
  }

  .map-action {
    font-size: 14px;
    color: var(--secondary);
  }

  .consult-section {
    margin-bottom: 80px;
  }

  .consult-card {
    background: var(--dark-2);
    border-radius: 30px;
    padding: 60px;
    border: 1px solid var(--dark-3);
  }

  .consult-card h2 {
    font-size: 32px;
    font-weight: 900;
    text-align: center;
    margin-bottom: 10px;
  }

  .consult-card > p {
    color: var(--gray);
    text-align: center;
    margin-bottom: 40px;
  }

  .consult-form {
    max-width: 700px;
    margin: 0 auto;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
    margin-bottom: 25px;
  }

  .form-group {
    margin-bottom: 25px;
  }

  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--light);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 15px 20px;
    background: var(--dark);
    border: 1px solid var(--dark-3);
    border-radius: 12px;
    color: var(--light);
    font-size: 15px;
    font-family: inherit;
    transition: border-color 0.3s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--gray);
  }

  .form-group select {
    cursor: pointer;
  }

  .form-group select option {
    background: var(--dark);
    color: var(--light);
  }

  .submit-btn {
    width: 100%;
    padding: 18px 40px;
    background: var(--primary);
    color: var(--dark);
    border: none;
    border-radius: 30px;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .submit-btn:hover {
    background: var(--secondary);
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0, 212, 255, 0.3);
  }

  .guide-section {
    margin-bottom: 40px;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .guide-card {
    background: var(--dark-2);
    border-radius: 20px;
    padding: 35px 25px;
    text-align: center;
    border: 1px solid var(--dark-3);
    transition: all 0.3s;
  }

  .guide-card:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
  }

  .guide-icon {
    font-size: 42px;
    margin-bottom: 15px;
  }

  .guide-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .guide-card p {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.6;
  }

  .footer {
    background: var(--dark-2);
    padding: 60px 0 30px;
    border-top: 1px solid var(--dark-3);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-brand h3 {
    font-size: 28px;
    font-weight: 900;
    color: var(--primary);
    margin-bottom: 10px;
  }

  .footer-brand p {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.7;
  }

  .footer h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .footer ul {
    list-style: none;
  }

  .footer ul li {
    margin-bottom: 10px;
  }

  .footer ul a {
    color: var(--gray);
    font-size: 14px;
    transition: color 0.3s;
  }

  .footer ul a:hover {
    color: var(--primary);
  }

  .footer-col:nth-child(2) ul li,
  .footer-col:nth-child(3) ul li,
  .footer-col:nth-child(4) ul li {
    color: var(--gray);
    font-size: 14px;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 30px;
    border-top: 1px solid var(--dark-3);
    color: var(--gray);
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .guide-grid {
      grid-template-columns: 1fr;
    }

    .footer-content {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .consult-card {
      padding: 40px 25px;
    }

    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>
